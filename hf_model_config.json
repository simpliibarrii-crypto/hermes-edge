{
  "model_type": "hermes-edge-litertlm",
  "library_name": "custom",
  "base_model": "google/gemma-3n-E2B-it",
  "local_first": true,
  "cloud_fallback_default": false,
  "backend_policy": {
    "default": "auto",
    "auto_order": [
      "gpu",
      "vulkan",
      "metal",
      "ane",
      "cpu"
    ],
    "primary": "gpu",
    "fallback": "cpu"
  },
  "runtime": {
    "litert_lm": true,
    "gemini_nano_aicore_optional": true,
    "mtp_optional": true,
    "benchmark_required_for_speed_claims": true
  },
  "profiles": [
    "tool-first",
    "gemma-3n-e2b-int4-litert",
    "gemma-3n-e4b-int4-litert",
    "gemma-4-e2b-mtp-litert",
    "gemini-nano-aicore"
  ],
  "install_extras": {
    "dev": "pip install -e .[dev]",
    "runtime": "pip install -e .[runtime]",
    "conversion": "pip install -e .[model,conversion,runtime]",
    "space": "pip install -e .[space,model]",
    "all": "pip install -e .[all]"
  }
}
