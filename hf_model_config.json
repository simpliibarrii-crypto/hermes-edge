{
  "model_name": "hermes-mobile-1b-litertlm",
  "display_name": "Hermes Mobile 1B (LiteRT-LM)",
  "format": "litertlm",
  "quantization": "int4_per_channel",
  "context_length": 4096,
  "parameters": "~1B",
  "framework": "litert-lm",
  "architecture": "decoder-only-gqa",
  "license": "apache-2.0",
  "tags": [
    "litert-lm",
    "litert",
    "on-device",
    "mobile",
    "agent",
    "tool-calling",
    "google-ai-edge-gallery"
  ],
  "library_name": "litert-lm",
  "pipeline_tag": "text-generation",
  "base_model": "hermes-edge/hermes-1b",
  "intended_org": "litert-community",
  "files": {
    "model": "hermes-mobile-1b-int4.litertlm",
    "model_card": "model_card.md"
  },
  "config": {
